{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./conventions.schema.json",
  "title": "Pi Conventions Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "extendsGlobal": {
      "type": "boolean"
    },
    "ignorePaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "structure": {
          "$ref": "#/$defs/structurePolicy"
        },
        "naming": {
          "$ref": "#/$defs/namingPolicy"
        },
        "documentation": {
          "$ref": "#/$defs/documentationPolicy"
        },
        "size": {
          "$ref": "#/$defs/sizePolicy"
        },
        "dependencies": {
          "$ref": "#/$defs/dependenciesPolicy"
        },
        "package": {
          "$ref": "#/$defs/packagePolicy"
        }
      }
    }
  },
  "$defs": {
    "enforcementMode": {
      "type": "string",
      "enum": [
        "warn",
        "confirm",
        "block"
      ]
    },
    "structureLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "prefixes"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "prefixes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "legacyZone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prefixes",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "prefixes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "onCreate": {
          "$ref": "#/$defs/enforcementMode"
        },
        "onEdit": {
          "$ref": "#/$defs/enforcementMode"
        }
      }
    },
    "newTopLevelFiles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "allowedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "structurePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "editMode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "sourceRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenSegments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/structureLayer"
          }
        },
        "legacyZones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legacyZone"
          }
        },
        "newTopLevelFiles": {
          "$ref": "#/$defs/newTopLevelFiles"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "namingPathKind": {
      "type": "string",
      "enum": [
        "file",
        "directory"
      ]
    },
    "namingCaseStyle": {
      "type": "string",
      "enum": [
        "kebab-case",
        "snake_case",
        "camelCase",
        "PascalCase"
      ]
    },
    "namingRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prefixes"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prefixes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "pathKinds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/namingPathKind"
          }
        },
        "requireCase": {
          "$ref": "#/$defs/namingCaseStyle"
        },
        "forbiddenNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "onCreate": {
          "$ref": "#/$defs/enforcementMode"
        },
        "onEdit": {
          "$ref": "#/$defs/enforcementMode"
        }
      }
    },
    "namingPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "editMode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/namingRule"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "documentationDeclaration": {
      "type": "string",
      "enum": [
        "interface",
        "type",
        "function",
        "class",
        "const"
      ]
    },
    "documentationRule": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false, "required": ["kind"], "anyOf": [{ "required": ["paths"] }, { "required": ["pathPattern"] }],
          "properties": {
            "id": { "type": "string" },
            "exclude": { "type": "array", "items": { "type": "string" } },
            "kind": { "const": "requireTsdocOnExports" },
            "paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "pathPattern": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "declarations": { "type": "array", "items": { "$ref": "#/$defs/documentationDeclaration" } },
            "requireRemarks": { "type": "boolean" }
          }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["kind"], "anyOf": [{ "required": ["paths"] }, { "required": ["pathPattern"] }],
          "properties": {
            "id": { "type": "string" },
            "exclude": { "type": "array", "items": { "type": "string" } },
            "kind": { "const": "requireFileOverview" },
            "paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "pathPattern": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "requiredTags": { "type": "array", "items": { "type": "string" } },
            "requiredSections": { "type": "array", "items": { "type": "string" } },
            "optionalSections": { "type": "array", "items": { "type": "string" } },
            "allowPackageDocumentation": { "type": "boolean" },
            "description": { "type": "string" },
            "minMatches": { "type": "integer", "minimum": 1 }
          }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["kind", "patterns"], "anyOf": [{ "required": ["paths"] }, { "required": ["pathPattern"] }],
          "properties": {
            "id": { "type": "string" },
            "exclude": { "type": "array", "items": { "type": "string" } },
            "kind": { "enum": ["forbidFileHeaders", "forbidCommentPatterns"] },
            "paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "pathPattern": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "patterns": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["kind"], "anyOf": [{ "required": ["paths"] }, { "required": ["pathPattern"] }],
          "properties": {
            "id": { "type": "string" },
            "exclude": { "type": "array", "items": { "type": "string" } },
            "kind": { "const": "todoFormat" },
            "paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "pathPattern": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "allowedTags": { "type": "array", "items": { "type": "string" } },
            "format": { "enum": ["TAG: description", "TAG: concrete action - referent"] }
          }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["kind", "commentKeywords"], "anyOf": [{ "required": ["paths"] }, { "required": ["pathPattern"] }],
          "properties": {
            "id": { "type": "string" },
            "exclude": { "type": "array", "items": { "type": "string" } },
            "kind": { "const": "requireRationaleComments" },
            "paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "pathPattern": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "commentKeywords": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "minMatches": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "documentationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "editMode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/documentationRule"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sizeLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prefixes"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prefixes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxLines": {
          "type": "integer",
          "minimum": 1
        },
        "maxBytes": {
          "type": "integer",
          "minimum": 1
        },
        "reason": {
          "type": "string"
        },
        "ignoreBlankLines": {
          "type": "boolean"
        },
        "ignoreCommentLines": {
          "type": "boolean"
        },
        "onCreate": {
          "$ref": "#/$defs/enforcementMode"
        },
        "onEdit": {
          "$ref": "#/$defs/enforcementMode"
        }
      },
      "anyOf": [
        {
          "required": [
            "maxLines"
          ]
        },
        {
          "required": [
            "maxBytes"
          ]
        }
      ]
    },
    "sizePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "editMode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "limits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sizeLimit"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dependencyRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from"
      ],
      "anyOf": [
        { "required": ["to"] },
        { "required": ["forbidSpecifiers"] }
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "from": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "to": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "allow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidSpecifiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "allowSpecifiers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "onCreate": {
          "$ref": "#/$defs/enforcementMode"
        },
        "onEdit": {
          "$ref": "#/$defs/enforcementMode"
        }
      }
    },
    "dependenciesPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "editMode": {
          "$ref": "#/$defs/enforcementMode"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependencyRule"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "packagePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "mode": { "$ref": "#/$defs/enforcementMode" },
        "editMode": { "$ref": "#/$defs/enforcementMode" },
        "manifests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requireFields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requireFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "piPackage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requireKeyword": { "type": "string" },
            "verifyResourcePaths": { "type": "boolean" }
          }
        },
        "npm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requireFilesCoverage": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
