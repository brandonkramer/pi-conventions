{
  "$schema": "./conventions.schema.json",
  "notes": [
    "Documentation checks are optional and intentionally warn by default."
  ],
  "policies": {
    "documentation": {
      "mode": "warn",
      "editMode": "warn",
      "rules": [
        {
          "kind": "requireTsdocOnExports",
          "paths": [
            "src/types.ts",
            "src/defaults.ts",
            "src/tools/{define,result,progress}.ts",
            "src/http/**",
            "src/scrape/pipeline.ts",
            "src/search/providers/**",
            "src/research/run.ts"
          ],
          "declarations": ["interface", "type", "function", "class", "const"],
          "requireRemarks": false
        },
        {
          "kind": "requireFileOverview",
          "paths": ["src/**/*.ts"],
          "requiredTags": ["@fileoverview"],
          "requiredSections": ["Design:"],
          "optionalSections": ["Performance:"],
          "minMatches": 1
        },
        {
          "kind": "forbidFileHeaders",
          "paths": ["src/**", "test/**"],
          "patterns": ["copyright", "licensed under", "spdx-license-identifier"]
        },
        {
          "kind": "forbidCommentPatterns",
          "paths": ["src/**", "test/**"],
          "patterns": ["PR #", "ticket"]
        },
        {
          "kind": "todoFormat",
          "paths": ["src/**", "test/**"],
          "allowedTags": ["TODO", "FIXME"],
          "format": "TAG: concrete action - referent"
        },
        {
          "kind": "requireRationaleComments",
          "paths": ["src/http/**"],
          "commentKeywords": ["SSRF", "security", "invariant", "because", "must", "not sufficient"],
          "minMatches": 1
        }
      ]
    }
  }
}
