{
  "name": "pi-conventions",
  "version": "0.2.3",
  "description": "Pi package for enforcing codebase conventions through structure and naming policies.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "conventions",
    "structure",
    "naming",
    "architecture"
  ],
  "author": "Brandon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brandonkramer/pi-conventions.git"
  },
  "homepage": "https://github.com/brandonkramer/pi-conventions#readme",
  "bugs": {
    "url": "https://github.com/brandonkramer/pi-conventions/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "schemas",
    "examples",
    "skills",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "vitest": "^4.1.2"
  }
}
